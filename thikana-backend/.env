# Server Configuration
PORT=5000
NODE_ENV=development

# Database Configuration (MySQL)
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=12345678
DB_NAME=thikana_db

# JWT Configuration
JWT_SECRET=super_secret_access_token_key_for_testing_thikana_app_32_chars
JWT_REFRESH_SECRET=super_secret_refresh_token_key_for_testing_thikana_app_32_chars
JWT_EXPIRE=15m
JWT_REFRESH_EXPIRE=7d

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000 # 15 minutes
RATE_LIMIT_MAX=100          # Limit each IP to 100 requests per windowMs
\
